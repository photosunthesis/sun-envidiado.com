---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PERSON_ID, SITE, absoluteUrl } from "../../utils/seo";
import bebiAppImage from "./_assets/bebi-app.png";
import rateStuffImage from "./_assets/rate-stuff-online.png";
import twentyFourToTwelveImage from "./_assets/24-to-12.png";

// rendered per request so `years` (and the meta/JSON-LD it feeds) stays current.
export const prerender = false;

const now = new Date();
const startDateString = "2019-03-01";
const startDate = new Date(startDateString);
const beforeAnniversary =
  now.getMonth() < startDate.getMonth() ||
  (now.getMonth() === startDate.getMonth() &&
    now.getDate() < startDate.getDate());

const years =
  now.getFullYear() - startDate.getFullYear() - (beforeAnniversary ? 1 : 0);

const description = `Software engineer with ${years}+ years of experience — currently focused on Swift and native iOS development.`;

const skills = [
  {
    label: "Frontend & Mobile",
    items: [
      "Swift & SwiftUI",
      "Flutter & Dart",
      "iOS & Android",
      "TypeScript, React, TanStack",
      "Vue.js, jQuery",
      "HTML/CSS, Responsive Web",
      "Razor Pages, Laravel Blade",
    ],
  },
  {
    label: "Backend & Database",
    items: [
      "C# & .NET",
      "Entity Framework",
      "PHP & Laravel",
      "RESTful APIs",
      "Firebase (Auth, Firestore)",
      "Cloudflare (Workers, R2)",
      "PostgreSQL, MySQL, MSSQL",
    ],
  },
  {
    label: "Architecture & DevOps",
    items: [
      "SOLID Principles",
      "Domain-Driven Design",
      "Repository & Service Patterns",
      "CI/CD Pipelines",
      "GitHub Actions, Azure DevOps",
      "Git, Docker, Fastlane",
      "LLM integration",
    ],
  },
];

const projects = [
  {
    title: "rate-stuff.online",
    url: "https://github.com/photosunthesis/rate-stuff.online",
    image: rateStuffImage,
    alt: "Screenshot of rate-stuff.online",
    description:
      "A website for rating and reviewing anything you can think of. Built with React, TanStack Start, and TypeScript on Cloudflare Workers — my deep dive into the modern serverless stack.",
  },
  {
    title: "Bebi App",
    url: "https://github.com/photosunthesis/bebi-app-flutter",
    image: bebiAppImage,
    alt: "Screenshot of Bebi App",
    description:
      "A Flutter app for couples — shared photo albums, a shared calendar, and cycle tracking, with a Firebase backend. A personal project for my partner and me.",
  },
  {
    title: "24-to-12",
    url: "https://github.com/photosunthesis/24-to-12",
    image: twentyFourToTwelveImage,
    alt: "Screenshot of the 24to12 web app",
    description:
      "A small web app that converts 24-hour time to 12-hour time, because I cannot do the subtraction in my head. Built in vanilla JavaScript over a single morning.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  url: absoluteUrl("/work", Astro.site),
  mainEntity: {
    "@id": PERSON_ID,
    "@type": "Person",
    name: SITE.name,
    url: SITE.url,
    jobTitle: "Software Engineer",
    description,
  },
};
---

<BaseLayout
  title="Work — Sun Envidiado"
  description={description}
  variant="doc"
  jsonLd={jsonLd}
>
  <article class="leading-relaxed">
    <h1 class="sr-only">Work</h1>

    <section class="space-y-[1lh]">
      <p>
        I've been building software for over <time datetime={startDateString}
          >{years}</time
        >+ years, engineering systems across the web, backend, and mobile.
      </p>
      <p>
        I started with Vue.js on the web, picked up C# (.NET) and PHP (Laravel)
        on the backend, then moved into mobile with Flutter and Dart. Right now,
        I'm building iOS apps with Swift.
      </p>
      <p>
        I've worked across fintech, healthcare, and a handful of other domains,
        tightening up CI/CD pipelines, shipping production iOS and Android apps,
        and architecting backends along the way. The full timeline (companies,
        dates, the long version) lives in <a
          class="link"
          href="/sun-envidiado-resume.pdf"
          target="_blank">my resume</a
        >.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-vim-link mb-[1lh] text-lg font-semibold">Skills</h2>
      <div class="grid grid-cols-1 gap-[1lh] md:grid-cols-3 md:gap-[2ch]">
        {
          skills.map((group) => (
            <div>
              <h3 class="mb-[0.5lh] font-semibold">{group.label}</h3>
              <ul class="space-y-[0.25lh]">
                {group.items.map((item) => (
                  <li class="flex gap-[1ch]">
                    <span class="text-vim-dim" aria-hidden="true">
                      ·
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-vim-link mb-[1lh] text-lg font-semibold">Projects</h2>
      <p class="mb-[1lh]">
        Here are some projects I've built outside of work; some polished, some
        scrappy, all made because I wanted to.
      </p>
      <ul class="space-y-[2lh]">
        {
          projects.map((project) => (
            <li class="grid grid-cols-1 gap-[1lh] md:grid-cols-[180px_1fr] md:gap-[2ch]">
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block aspect-4/3 w-full overflow-hidden rounded border border-neutral-800"
              >
                <Picture
                  src={project.image}
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  widths={[200, 400, 600]}
                  sizes="(max-width: 768px) 100vw, 200px"
                  loading="lazy"
                  alt={project.alt}
                  class="h-full w-full object-cover"
                />
              </a>
              <div>
                <a
                  class="link font-semibold"
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.title} <span aria-hidden="true">↗</span>
                </a>
                <p class="mt-[0.25lh]">{project.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</BaseLayout>
