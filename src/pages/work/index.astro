---
import { Picture } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PERSON_ID, SITE, absoluteUrl } from "../../utils/seo";
import bebiAppImage from "./_assets/bebi-app.png";
import haandvaerkerImage from "./_assets/haandvaerker-dk.png";
import rateStuffImage from "./_assets/rate-stuff-online.png";

const startDate = new Date("2019-03-01");
const today = new Date();
let years = today.getFullYear() - startDate.getFullYear();
if (
  today.getMonth() < startDate.getMonth() ||
  (today.getMonth() === startDate.getMonth() &&
    today.getDate() < startDate.getDate())
) {
  years--;
}

const description = `Software engineer with ${years}+ years of experience — currently focused on Swift and native iOS development.`;

const projects = [
  {
    title: "rate-stuff.online",
    url: "https://rate-stuff.online",
    image: rateStuffImage,
    alt: "Screenshot of rate-stuff.online",
    description:
      "Built with React and TanStack Start, deployed on Cloudflare Workers. My deep dive into React and serverless.",
  },
  {
    title: "Bebi App",
    url: "https://github.com/photosunthesis/bebi-app-flutter",
    image: bebiAppImage,
    alt: "Screenshot of Bebi App",
    description:
      "A couples app with image sharing, shared calendar, and cycle tracking.",
  },
  {
    title: "Haandvaerker.dk",
    url: "https://www.haandvaerker.dk/",
    image: haandvaerkerImage,
    alt: "Screenshot of Haandvaerker.dk",
    description:
      "Platform connecting homeowners with craftsmen in Denmark. Built both Flutter apps and contributed to the backend.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  url: absoluteUrl("/work", Astro.site),
  mainEntity: {
    "@id": PERSON_ID,
    "@type": "Person",
    name: SITE.name,
    url: SITE.url,
    jobTitle: "Software Engineer",
    description,
  },
};
---

<BaseLayout
  title="Work — Sun Envidiado"
  description={description}
  variant="doc"
  jsonLd={jsonLd}
>
  <article class="leading-relaxed">
    <h1 class="sr-only">Work</h1>

    <section class="space-y-[1lh]">
      <p>
        I've been building software for {years}+ years, starting with web before
        shifting to mobile. My current focus is iOS development with Swift.
      </p>
      <p>
        Along the way, I developed skills in Flutter and Dart for cross-platform
        apps, JavaScript (React and Vue), PHP (Laravel), C# (.NET), and the
        Firebase and Cloudflare ecosystems.
      </p>
      <p>
        You can view my complete resume <a
          class="link"
          href="/sun-envidiado-resume.pdf"
          target="_blank">here</a
        >.
      </p>
      <p>
        If you'd like to get in touch, head over to the <a
          class="link"
          href="/contact">contact page</a
        >.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-vim-link mb-[1lh] text-lg font-semibold">
        Project Showcase
      </h2>
      <ul class="space-y-[2lh]">
        {
          projects.map((project) => (
            <li class="grid grid-cols-1 gap-[1lh] md:grid-cols-[180px_1fr] md:gap-[2ch]">
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block aspect-4/3 w-full overflow-hidden rounded border border-neutral-800"
              >
                <Picture
                  src={project.image}
                  formats={["avif", "webp"]}
                  fallbackFormat="jpg"
                  widths={[200, 400, 600]}
                  sizes="(max-width: 768px) 100vw, 200px"
                  loading="lazy"
                  alt={project.alt}
                  class="h-full w-full object-cover"
                />
              </a>
              <div>
                <a
                  class="link font-semibold"
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.title} <span aria-hidden="true">↗</span>
                </a>
                <p class="mt-[0.25lh]">{project.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</BaseLayout>
