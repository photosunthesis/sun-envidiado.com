---
import BaseLayout from "../layouts/BaseLayout.astro";

const kaomojis = [
  "гғҪ(гғј_гғј )гғҺ",
  "гғҪ(Вҙгғј` )в”Ң",
  "в”җ(вҖҳпҪһ` )в”Ң",
  "гғҪ(гҖҖпҝЈРҙпҝЈ)гғҺ",
  "в”җ(пҝЈгғҳпҝЈ)в”Ң",
  "гғҪ(пҝЈпҪһпҝЈгҖҖ)гғҺ",
  "в•®(пҝЈ_пҝЈ)в•ӯ",
  "гғҪ(ЛҮгғҳЛҮ)гғҺ",
  "в”җ(пҝЈпҪһпҝЈ)в”Ң",
  "в•®(пҝЈпҪһпҝЈ)в•ӯ",
  "в”җ( Вҙ Рҙ ` )в”Ң",
  "в•®(пё¶пёҝпё¶)в•ӯ",
  "в”җ(пҝЈвҲҖпҝЈ)в”Ң",
  "в”җ( Лҳ пҪӨ Лҳ )в”Ң",
  "в•®( Лҳ пҪӨ Лҳ )в•ӯ",
  "в”җ( Лҳ_Лҳ )в”Ң",
  "в•®( Лҳ_Лҳ )в•ӯ",
  "в”җ(пҝЈгғ®пҝЈ)в”Ң",
];
---

<BaseLayout
  title="404 вҖ” Page Not Found"
  description="The page you are looking for does not exist."
  noindex
>
  <article class="max-w-[60ch] leading-relaxed">
    <h1 class="text-vim-link mb-[0.5lh] text-xl font-semibold">
      404 <span id="kaomoji" class="text-vim-fg ml-[1ch]">{kaomojis[0]}</span>
    </h1>
    <p>
      The page you're looking for doesn't exist. Double-check the URL вҖ” it may
      be a typo, or the page could have been removed.
    </p>
    <p class="mt-[1lh]">
      <a class="link" href="/">вҶҗ Back to homepage</a>
    </p>
  </article>

  <script is:inline define:vars={{ kaomojis }}>
    var el = document.getElementById("kaomoji");
    if (el) el.textContent = kaomojis[Math.floor(Math.random() * kaomojis.length)];
  </script>
</BaseLayout>
