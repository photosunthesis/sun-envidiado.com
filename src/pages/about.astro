---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PERSON_ID } from "../utils/seo";

const description =
  "About Sun Envidiado — a software developer from the Philippines.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: { "@id": PERSON_ID },
};
---

<BaseLayout
  title="About — Sun Envidiado"
  description={description}
  jsonLd={jsonLd}
>
  <article class="max-w-[70ch] space-y-[1lh] leading-relaxed">
    <p>
      My name is <span class="text-vim-link">Sun Envidiado</span>. And yes, I am
      named after <em>the Sun</em>. I'm a software developer from the
      Philippines, currently living in Metro Manila.
    </p>
    <p>
      Outside of programming, you'll find me watching anime and films, playing
      videogames, doing karaoke, or scrolling through TikTok for unhealthy
      amounts of time. I cook too, though I'm barely decent at it. My dream is
      to one day have a proper kitchen with quality tools and utensils so I can
      make Michelin-star meals.
    </p>
    <p>
      The design of this website is inspired by vim and TUIs. Something about
      them has always felt cool and hacky and delightfully computer-y to me
      (though ironically, I use VS Code to actually build things). This is my
      tiny corner of the internet where you can find a mix of software projects,
      blog posts, and random thoughts about life, anime, games, and everything
      in between.
    </p>
  </article>
</BaseLayout>
