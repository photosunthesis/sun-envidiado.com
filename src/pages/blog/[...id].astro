---
import type { ImageMetadata } from "astro";
import { Picture, getImage } from "astro:assets";
import { getCollection, render } from "astro:content";
import Newsletter from "../../components/Newsletter.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  PERSON_ID,
  PERSON_SCHEMA,
  WEBSITE_ID,
  WEBSITE_SCHEMA,
  absoluteUrl,
} from "../../utils/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, cover, coverAlt } =
  post.data;

const readableText = (post.body ?? "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]*`/g, " ")
  .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
  .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
  .replace(/<[^>]+>/g, " ")
  .replace(/^import\s.+$/gm, " ")
  .replace(/[#>*_~|=`-]/g, " ");
const wordCount = readableText.trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));

let coverImage: ImageMetadata | undefined;
if (cover) {
  const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/content/blog/**/*.{jpeg,jpg,png,gif,webp,avif}",
  );
  const imagePath = `/src/content/blog/${cover.replace(/^\.\//, "")}`;
  const loader = images[imagePath];
  if (loader) coverImage = (await loader()).default;
}

const COVER_WIDTHS = [400, 600, 900];
const COVER_SIZES = "(max-width: 600px) 100vw, 500px";

let coverPreloadSrcset: string | undefined;
if (coverImage) {
  const variants = await Promise.all(
    COVER_WIDTHS.map(async (width) => {
      const img = await getImage({ src: coverImage!, format: "avif", width });
      return `${img.src} ${width}w`;
    }),
  );
  coverPreloadSrcset = variants.join(", ");
}

const canonical = absoluteUrl(Astro.url.pathname, Astro.site);
const ogImage = coverImage
  ? absoluteUrl(coverImage.src, Astro.site)
  : undefined;

const pubISO = pubDate.toISOString();
const updISO = updatedDate?.toISOString();

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonical}#blogposting`,
  headline: title,
  description,
  url: canonical,
  datePublished: pubISO,
  ...(updISO && { dateModified: updISO }),
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  author: { "@id": PERSON_ID },
  publisher: { "@id": PERSON_ID },
  isPartOf: { "@id": WEBSITE_ID },
  ...(coverImage && {
    image: {
      "@type": "ImageObject",
      url: ogImage,
      width: coverImage.width,
      height: coverImage.height,
    },
  }),
  ...(tags && tags.length > 0 && { keywords: tags.join(", ") }),
};

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout
  title={title}
  description={description}
  variant="doc"
  type="article"
  pubDate={pubISO}
  updatedDate={updISO}
  tags={tags}
  ogImage={ogImage}
  ogImageWidth={coverImage?.width}
  ogImageHeight={coverImage?.height}
  wordCount={wordCount}
  readingMinutes={readingMinutes}
  jsonLd={[WEBSITE_SCHEMA, PERSON_SCHEMA, blogPostingSchema]}
>
  {
    coverPreloadSrcset && (
      <Fragment slot="head">
        <link
          rel="preload"
          as="image"
          type="image/avif"
          imagesrcset={coverPreloadSrcset}
          imagesizes={COVER_SIZES}
          fetchpriority="high"
        />
      </Fragment>
    )
  }

  <article aria-labelledby="post-title">
    {
      coverImage && (
        <Picture
          class="mb-[1lh] block h-auto w-full rounded"
          src={coverImage}
          formats={["avif", "webp"]}
          fallbackFormat="jpg"
          widths={COVER_WIDTHS}
          sizes={COVER_SIZES}
          loading="eager"
          fetchpriority="high"
          alt={coverAlt!}
        />
      )
    }
    <header class="mb-[1lh]">
      <h1
        id="post-title"
        class="text-vim-link mb-[0.25lh] text-xl font-semibold"
      >
        {title}
      </h1>
      <p class="text-vim-dim m-0">
        <time datetime={pubISO}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <span>
              {" · Updated "}
              <time datetime={updISO}>{formatDate(updatedDate)}</time>
            </span>
          )
        }
      </p>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <Newsletter hasDivider />

    <p class="mt-8">
      <button
        id="back-to-top"
        type="button"
        class="hover:text-vim-link cursor-pointer border-none bg-transparent p-0 focus:outline-none"
      >
        ↑ Back to top
      </button>
    </p>
  </article>
</BaseLayout>

<script>
  document.getElementById("back-to-top")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
