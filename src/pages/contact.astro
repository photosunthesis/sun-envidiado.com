---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PERSON_ID, SITE, absoluteUrl } from "../utils/seo";

const description =
  "Want to work together, chat about a project, or just say hi? Here's how to reach me.";
const email = "hello@sun-envidiado.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact",
  description,
  url: absoluteUrl("/contact", Astro.site),
  mainEntity: {
    "@type": "Person",
    "@id": PERSON_ID,
    name: SITE.name,
    email,
    url: SITE.url,
    contactPoint: {
      "@type": "ContactPoint",
      email,
      contactType: "Professional Inquiries",
    },
    sameAs: [
      "https://github.com/photosunthesis",
      "https://www.linkedin.com/in/sunenvidiado/",
    ],
  },
};
---

<BaseLayout
  title="Contact — Sun Envidiado"
  description={description}
  jsonLd={jsonLd}
>
  <article class="max-w-[60ch] leading-relaxed">
    <p>
      The best way to reach me is by email at <a
        class="link"
        href={`mailto:${email}`}>{email}</a
      >.
    </p>
  </article>
</BaseLayout>
