---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PERSON_SCHEMA, WEBSITE_SCHEMA } from "../utils/seo";

const tagline = "I'm a mediocre programmer, epic pro gamer, and a karaoke menace.";
const description = `Sun Envidiado — ${tagline}. Welcome to my tiny corner on the internet.`;

const sections = [
  { href: "/about", label: ":about", desc: "to learn more about me" },
  { href: "/blog", label: ":blog", desc: "to see my blog posts" },
  { href: "/contact", label: ":contact", desc: "to get in touch" },
  { href: "/work", label: ":work", desc: "for my work details" },
];
---

<BaseLayout
  title="Sun Envidiado"
  description={description}
  jsonLd={[WEBSITE_SCHEMA, PERSON_SCHEMA]}
>
  <article class="w-full max-w-[44ch] leading-relaxed">
    <img
      src="/sun-logo.svg"
      alt=""
      aria-hidden="true"
      width="48"
      height="48"
      class="mx-auto mb-[0.5lh] block h-12 w-12"
    />
    <h1 class="text-vim-link text-center font-semibold">Sun Envidiado</h1>
    <p
      class="mt-[1lh] text-center min-[325px]:text-justify min-[325px]:[text-align-last:center]"
    >
      {tagline} Anyway, welcome to the website.
    </p>
    <nav class="mt-[1lh]" aria-label="Site sections">
      <ul
        class="space-y-2 font-mono min-[325px]:grid min-[325px]:w-full min-[325px]:grid-cols-[auto_auto_1fr_auto] min-[325px]:gap-x-[1.5ch] min-[325px]:space-y-0 sm:gap-x-[2.5ch]"
      >
        {
          sections.map((s) => (
            <li class="min-[325px]:contents">
              <span>{`go to `}</span>
              <a class="link" href={s.href}>
                {s.label}
              </a>
              <span aria-hidden="true" class="hidden min-[325px]:block" />
              <span>{` ${s.desc}.`}</span>
            </li>
          ))
        }
      </ul>
    </nav>
  </article>
</BaseLayout>
