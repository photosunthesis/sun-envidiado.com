---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PERSON_SCHEMA, WEBSITE_SCHEMA } from "../utils/seo";

const tagline = "I'm a software developer, gamer, and karaoke menace.";
const description = `Sun Envidiado — ${tagline}. Welcome to my tiny corner on the internet.`;

const sections = [
  { href: "/about", label: ":about", desc: "to learn more about me" },
  { href: "/blog", label: ":blog", desc: "to see my blog posts" },
  { href: "/contact", label: ":contact", desc: "to get in touch" },
  { href: "/work", label: ":work", desc: "for my work details" },
];
---

<BaseLayout
  title="Sun Envidiado"
  description={description}
  jsonLd={[WEBSITE_SCHEMA, PERSON_SCHEMA]}
>
  <article class="w-full max-w-[40ch] leading-relaxed">
    <img
      src="/sun-logo.svg"
      alt=""
      aria-hidden="true"
      width="48"
      height="48"
      class="mx-auto mb-[0.5lh] block h-12 w-12"
    />

    <h1 class="text-vim-link text-center font-semibold">Sun Envidiado</h1>

    <p class="mt-[1lh] text-center min-[375px]:[text-align-last:center]">
      {tagline} Welcome to my website.
    </p>

    <nav class="mt-[1lh]" aria-label="Site sections">
      <ul
        class="mx-auto w-fit space-y-1 font-mono whitespace-nowrap min-[375px]:grid min-[375px]:grid-cols-[auto_auto_auto] min-[375px]:space-y-0 min-[375px]:gap-x-[clamp(0.75ch,1vw,2.5ch)]"
      >
        {
          sections.map((s) => (
            <li class="min-[375px]:contents">
              <span>{`go to `}</span>
              <a class="link" href={s.href}>
                {s.label}
              </a>
              <span>{` ${s.desc}.`}</span>
            </li>
          ))
        }
      </ul>
    </nav>
  </article>
</BaseLayout>
