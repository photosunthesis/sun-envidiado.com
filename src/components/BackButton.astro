---
interface Props {
  href?: string;
  label?: string;
  class?: string;
}

const { href = '/', label = '← Back', class: className } = Astro.props;
---

<div class:list={['back-button-wrapper', className]}>
  <a href={href} aria-label="Go back or to homepage" class="js-back-button">{label}</a>
</div>

<script>
  const handleBackClick = (e: Event) => {
    if (window.history.length > 1) {
      e.preventDefault();
      window.history.back();
    }
  };

  const bindBackButtons = () => {
    document.querySelectorAll('a.js-back-button').forEach((button) => {
      button.removeEventListener('click', handleBackClick);
      button.addEventListener('click', handleBackClick);
    });
  };

  bindBackButtons();
  document.addEventListener('astro:page-load', bindBackButtons);
</script>

<style lang="scss">
  .back-button-wrapper {
    padding-bottom: 1rem;

    a {
      color: var(--comment);
      padding: 0;
      text-decoration: none;
      cursor: pointer;
      font-family: inherit;
      background: none;
      border: none;
      display: inline-block;

      &:hover {
        color: var(--cyan);
        text-decoration: underline;
      }
    }
  }
</style>
