---
interface Props {
  hasDivider?: boolean;
  class?: string;
}

const { hasDivider = false, class: className } = Astro.props;
---

{hasDivider && <p class="text-vim-dim mt-[2lh] mb-[2lh]">---</p>}
<section class:list={["w-full", className]}>
  <p class="mb-[0.75lh]">
    Subscribe to get an email when I publish a new post (or use <a
      class="link"
      href="/rss.xml">RSS</a
    >). No spam. I promise!
  </p>

  <form id="newsletter-form" class="flex flex-wrap items-center gap-[1ch]">
    <label for="newsletter-email" class="sr-only">Email address</label>
    <input
      type="email"
      id="newsletter-email"
      name="email"
      placeholder="your@email.com"
      required
      class="border-vim-dim text-vim-fg placeholder:text-vim-dim focus:border-vim-link min-w-[18ch] flex-1 border bg-transparent px-[1ch] py-[0.25lh] focus:outline-none"
    />
    <button
      type="submit"
      class="bg-vim-link text-vim-bg cursor-pointer border-none px-4 py-[0.25lh] disabled:cursor-wait disabled:opacity-50 md:px-10"
    >
      Subscribe
    </button>
  </form>
  <p id="newsletter-message" class="mt-[0.25lh] min-h-lh" aria-live="polite">
  </p>
</section>

<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement;
  const messageEl = document.getElementById("newsletter-message");
  const btn = form?.querySelector("button");

  if (form && messageEl && btn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get("email");
      const originalBtnText = btn.textContent;

      btn.disabled = true;
      btn.textContent = "Sending...";
      messageEl.textContent = "";
      messageEl.classList.remove("text-vim-link", "text-vim-dim");

      try {
        const res = await fetch("/api/subscribe-to-blog", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        await res.json();
        if (!res.ok) throw new Error();

        messageEl.textContent =
          "[ok] Check your email to confirm your subscription.";
        messageEl.classList.add("text-vim-link");
        form.reset();
      } catch {
        messageEl.textContent =
          "[err] Something went wrong. Please try again later.";
        messageEl.classList.add("text-vim-dim");
      } finally {
        btn.disabled = false;
        btn.textContent = originalBtnText;
      }
    });
  }
</script>
