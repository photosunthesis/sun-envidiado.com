---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  thumbhash: string;
  alt: string;
  widths?: number[];
  sizes?: string;
  formats?: ("avif" | "webp" | "png" | "jpg" | "jpeg")[];
  fallbackFormat?: "png" | "jpg" | "jpeg" | "webp";
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  inferSize?: boolean;
}

const { thumbhash, class: className, ...rest } = Astro.props;
---

<span
  data-lqip
  class="block"
  style={`background-image: url('${thumbhash}'); background-size: cover; background-position: center; background-color: var(--color-vim-code);`}
>
  <Picture
    {...rest}
    class={`opacity-0 transition-opacity duration-500 ease-out motion-reduce:transition-none${className ? ` ${className}` : ""}`}
  />
</span>
